{
  "name": "@astra/auth-kit",
  "version": "0.1.0",
  "description": "Lightweight authentication kit for Next.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src --format esm,cjs --dts --outDir dist --clean",
    "dev": "tsup src/index.ts --watch --format esm,cjs --dts --outDir dist",
    "test": "jest --config ./jest.config.js"
  },
  "keywords": [],
  "author": "astra-void",
  "license": "MIT",
  "peerDependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-typescript": "^7.27.1",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.7",
    "babel-jest": "^29.0.0",
    "jest": "^29.7.0",
    "next": "^15.3.3",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@panva/hkdf": "^1.2.1",
    "argon2": "^0.43.0",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "jose": "^6.0.11",
    "uuid": "^11.1.0"
  }
}
