{
  "name": "@astra-void/auth-kit",
  "version": "0.2.0-alpha.27",
  "description": "Lightweight authentication kit for Next.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapter": {
      "types": "./dist/adapter/index.d.ts",
      "import": "./dist/adapter/index.js",
      "require": "./dist/adapter/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js",
      "require": "./dist/middleware/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react/passkey": {
      "types": "./dist/react/passkey/index.d.ts",
      "import": "./dist/react/passkey/index.js",
      "require": "./dist/react/passkey/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src --format esm,cjs --dts --outDir dist --clean",
    "dev": "tsup src/index.ts --watch --format esm,cjs --dts --outDir dist",
    "lint": "eslint",
    "test": "jest --config ./jest.config.js"
  },
  "keywords": [
    "jwt",
    "authkit",
    "nextjs"
  ],
  "author": "astra-void",
  "license": "MIT",
  "peerDependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "argon2": "^0.43.0",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/css": "^0.9.0",
    "@eslint/js": "^9.29.0",
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.6.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "babel-jest": "^29.7.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "next": "^15.3.4",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@panva/hkdf": "^1.2.1",
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "axios": "^1.10.0",
    "jose": "^6.0.11",
    "uuid": "^11.1.0"
  }
}
