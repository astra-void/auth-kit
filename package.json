{
  "name": "@astra-void/auth-kit",
  "version": "0.5.4",
  "description": "Next.js authentication with passkey support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js",
      "require": "./dist/middleware/index.cjs"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js",
      "require": "./dist/store/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src --format esm,cjs --dts --outDir dist --clean",
    "dev": "tsup src/index.ts --watch --format esm,cjs --dts --outDir dist",
    "lint": "eslint",
    "test": "jest --config ./jest.config.js"
  },
  "keywords": [
    "jwt",
    "authkit",
    "nextjs",
    "passkey",
    "authentication",
    "login",
    "register",
    "webauthn",
    "auth",
    "prisma",
    "react"
  ],
  "author": "astra-void",
  "license": "MIT",
  "peerDependencies": {
    "argon2": "^0.43.0",
    "bcrypt": "^6.0.0",
    "next": "^15.3.3",
    "nodemailer": "^7.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/css": "^0.9.0",
    "@eslint/js": "^9.30.1",
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.6.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.16.0",
    "@types/react": "^19.1.8",
    "babel-jest": "^29.7.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "next": "^15.3.5",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "@types/nodemailer": "^6.4.17",
    "axios": "^1.10.0",
    "jose": "^6.0.11",
    "uuid": "^11.1.0"
  }
}
